{
  "name": "@take-a-break/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit --project tsconfig.json",
    "validate:runtime": "tsx -e \"import('./src/server.js').then(s => s.buildServer().then(server => { console.log('✅ Server validation passed'); process.exit(0); }).catch(e => { console.error('❌ Server validation failed:', e); process.exit(1); }))\""
  },
  "dependencies": {
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/swagger": "^8.10.0",
    "@fastify/swagger-ui": "^1.10.0",
    "@take-a-break/config": "workspace:*",
    "@take-a-break/firebase": "workspace:*",
    "@take-a-break/types": "workspace:*",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "fastify": "^4.25.2",
    "fastify-plugin": "^4.5.1",
    "yaml": "^2.3.4"
  }
}
